{
  "name": "developer",
  "display_name": "Developer",
  "version": "1.2.4",
  "description": "Unified development experience for building, evolving, and shipping agent-index collections \u2014 from first idea through marketplace submission. v1.2.4: fix-up release \u2014 bumps preflight.md frontmatter version to match its manifest. The 1.2.3 release expanded preflight.md with two new sub-checks but left the frontmatter version at 1.2.2 while bumping the manifest to 1.2.3 \u2014 the exact drift the 1.2.2 check is meant to catch. Caught post-publish on dev_install upgrade. v1.2.3: preflight Step 4 gains two release-artifact integrity checks \u2014 adapter supported-ops vs bundle implementation, and shipped shell-script line endings. v1.2.2: per-capability manifest-vs-frontmatter version drift check.",
  "author": "agent-index",
  "license": "open",
  "category": "developer-tools",
  "agent_index_min_version": "2.1.0",
  "api": [
    {
      "name": "develop",
      "triggers": [
        {
          "phrase": "develop a collection",
          "capability": "develop",
          "description": "Start or continue developing a collection"
        },
        {
          "phrase": "work on my collection",
          "capability": "develop",
          "description": "Open the development workflow for a collection"
        },
        {
          "phrase": "build my collection",
          "capability": "develop",
          "description": "Continue building a collection in progress"
        }
      ]
    },
    {
      "name": "preflight",
      "triggers": [
        {
          "phrase": "preflight check",
          "capability": "preflight",
          "description": "Run pre-submission checks on a collection"
        },
        {
          "phrase": "is my collection ready",
          "capability": "preflight",
          "description": "Validate a collection before publishing"
        },
        {
          "phrase": "ready to ship",
          "capability": "preflight",
          "description": "Run final checks before marketplace submission"
        }
      ]
    },
    {
      "name": "developer-guide",
      "triggers": [
        {
          "phrase": "developer guide",
          "capability": "developer-guide",
          "description": "Access the collection development reference"
        },
        {
          "phrase": "how to build collections",
          "capability": "developer-guide",
          "description": "Read the development guide"
        },
        {
          "phrase": "collection authoring reference",
          "capability": "developer-guide",
          "description": "Open the developer reference docs"
        }
      ]
    },
    {
      "name": "developer-tutorial",
      "triggers": [
        {
          "phrase": "developer tutorial",
          "capability": "developer-tutorial",
          "description": "Get a guided intro to collection development"
        },
        {
          "phrase": "how does development work",
          "capability": "developer-tutorial",
          "description": "Learn the collection development workflow"
        }
      ]
    },
    {
      "name": "optimize",
      "triggers": [
        {
          "phrase": "optimize my collection",
          "capability": "optimize",
          "description": "Analyze and improve a collection's performance"
        },
        {
          "phrase": "improve my collection",
          "capability": "optimize",
          "description": "Get suggestions for collection improvements"
        },
        {
          "phrase": "collection optimization",
          "capability": "optimize",
          "description": "Run optimization analysis on a collection"
        }
      ]
    }
  ],
